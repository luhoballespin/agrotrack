PORT=5000
# Atlas (producción)
MONGODB_URI=mongodb+srv://USUARIO:PASSWORD@cluster0.xxxxx.mongodb.net/agrotrack?retryWrites=true&w=majority
# Fallback opcional si tu red falla con querySrv (no suele hacer falta en Render)
# MONGODB_URI_STANDARD=mongodb://USUARIO:PASSWORD@host1:27017,host2:27017,host3:27017/agrotrack?retryWrites=true&w=majority&ssl=true&authSource=admin
# Local:
# MONGODB_URI=mongodb://127.0.0.1:27017/agrotrack
JWT_SECRET=generar_un_secreto_largo_minimo_32_caracteres
JWT_EXPIRES_IN=7d
ADMIN_USER=admin
ADMIN_PASS=cambiar_esta_contraseña
CLOUDINARY_CLOUD_NAME=
CLOUDINARY_API_KEY=
CLOUDINARY_API_SECRET=
FRONTEND_URL=https://tu-frontend.vercel.app
# Alternativa para varios orígenes separados por coma:
# FRONTEND_URLS=https://tu-frontend.vercel.app,http://localhost:5173
# Para previews de Vercel (opcional):
ALLOW_VERCEL_PREVIEWS=false
